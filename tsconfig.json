{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@boxiaolanya2008/pi-ai": ["./packages/ai/src/index.ts"],
			"@boxiaolanya2008/pi-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@boxiaolanya2008/pi-ai/*": ["./packages/ai/src/*"],
			"@boxiaolanya2008/pi-ai/dist/*": ["./packages/ai/src/*"],
			"@boxiaolanya2008/pi-agent-core": ["./packages/agent/src/index.ts"],
			"@boxiaolanya2008/pi-agent-core/*": ["./packages/agent/src/*"],
			"@boxiaolanya2008/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@boxiaolanya2008/pi-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@boxiaolanya2008/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@boxiaolanya2008/pi-mom": ["./packages/mom/src/index.ts"],
			"@boxiaolanya2008/pi-mom/*": ["./packages/mom/src/*"],
			"@boxiaolanya2008/pi": ["./packages/pods/src/index.ts"],
			"@boxiaolanya2008/pi/*": ["./packages/pods/src/*"],
			"@boxiaolanya2008/pi-tui": ["./packages/tui/src/index.ts"],
			"@boxiaolanya2008/pi-tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*"],
	"exclude": ["**/dist/**", "**/examples/**"]
}
